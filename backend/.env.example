SECRET_KEY=change-this-to-a-random-secret-key-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
UPLOAD_DIR=uploads

# Phase 3 — push notifications via Expo Push Service
# No Firebase setup needed; Expo handles delivery for iOS + Android
EXPO_PUSH_URL=https://exp.host/--/api/v2/push/send
